# ============================================================
# .env dùng CHUNG cho cả mcp/ và rag/. Copy file này thành .env
# rồi điền giá trị thật, KHÔNG commit .env lên git.
# ============================================================

# --- MCP server (đọc bởi mcp/src/config/configs.py) ---
SERVER_NAME=profile_lookup
URL_HOST_SERVER=0.0.0.0
PORT_SERVER=8090

# --- Archive API — nguồn dữ liệu gốc (đọc bởi rag/config/rag_config.py) ---
ARCHIVE_API_BASE_URL=http://192.168.1.46:4000
ARCHIVE_API_PATH=/api/public/archives
ARCHIVE_API_PAGE_SIZE=100
HTTP_TIMEOUT_SECONDS=60

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
RAG_COLLECTION_ARCHIVES=archives
RAG_COLLECTION_CHUNKS=document_chunks

# --- Embedding models (fastembed, chạy local, tải model lần đầu sẽ cache) ---
DENSE_MODEL_NAME=intfloat/multilingual-e5-large
SPARSE_MODEL_NAME=Qdrant/bm25
DENSE_VECTOR_SIZE=1024

# --- OCR ---
OCR_LANG=vie
OCR_MIN_CHARS_PER_PAGE=50
OCR_DPI=200
OCR_CONCURRENCY=4

# --- Chunking ---
CHUNK_SIZE_CHARS=1200
CHUNK_OVERLAP_CHARS=200

# --- Sync state (SQLite checkpoint cho incremental sync) ---
SYNC_DB_PATH=./data/sync_state.db

# --- Log level riêng của rag/ (xem rag/logger.py) ---
RAG_LOG_LEVEL=INFO
